{
  "name": "your-command",
  "private": true,
  "version": "1.1.0",
  "homepage": "https://alexup71rus.github.io/Your-Command---Game/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexup71rus/Your-Command---Game.git"
  },
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings 0",
    "precommit": "node scripts/precommit.mjs",
    "prepare": "node scripts/setup-hooks.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:ai": "vitest run src/game/ai/combatScenarios.test.ts src/game/ai/defenseScenarios.test.ts src/game/ai/economyScenarios.test.ts src/game/ai/planner.test.ts",
    "test:stable": "vitest run --exclude src/game/ai/combatScenarios.test.ts --exclude src/game/ai/defenseScenarios.test.ts --exclude src/game/ai/economyScenarios.test.ts"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.1.0",
    "vitest": "^3.2.4"
  }
}
